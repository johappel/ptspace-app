PTSPACE_DATA_DIR=.ptspace-data
PTSPACE_WORKSPACES_DIR=.ptspace-runtime
PTSPACE_KERNEL_DIR=../pedagogical-thinking-space
PTSPACE_PLANNING_WORKSPACES_DIR=../pedagogical-thinking-space/workspace
PTSPACE_KERNEL_WRITE_ENABLED=false
PTSPACE_EXTERNAL_KERNEL_CONTEXT_ENABLED=false
PTSPACE_KERNEL_WRITABLE_DIRS=capabilities,knowledge,queue,services,workspace
PTSPACE_HARNESS=mock
PTSPACE_REAL_HARNESS_ENABLED=false
PTSPACE_OPENCODE_RUNNER=docker
PTSPACE_OPENCODE_DOCKER_IMAGE=ptspace/opencode-test:1.17.13
PTSPACE_OPENCODE_COMMAND=opencode
PTSPACE_OPENCODE_ALLOW_NETWORK=false
PTSPACE_OPENCODE_TIMEOUT_MS=120000
PTSPACE_OPENCODE_PROVIDER=openrouter
PTSPACE_OPENCODE_MODEL=tencent/hy3:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY nie in Chat, Workspace oder Git speichern. Nur lokal in .env oder Secret-Store setzen.
# OPENROUTER_API_KEY=
# Optional für einen kontrollierten lokalen Test, nicht für produktionsnahe Isolation:
# PTSPACE_HARNESS=opencode-docker
# PTSPACE_REAL_HARNESS_ENABLED=true
# PTSPACE_OPENCODE_RUNNER=local
BACKEND_PORT=5174
PUBLIC_BACKEND_URL=http://127.0.0.1:5174
