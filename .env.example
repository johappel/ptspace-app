PTSPACE_DATA_DIR=.ptspace-data
PTSPACE_WORKSPACES_DIR=workspaces
PTSPACE_HARNESS=mock
PTSPACE_REAL_HARNESS_ENABLED=false
PTSPACE_OPENCODE_RUNNER=docker
PTSPACE_OPENCODE_DOCKER_IMAGE=
PTSPACE_OPENCODE_COMMAND=opencode
PTSPACE_OPENCODE_ALLOW_NETWORK=false
PTSPACE_OPENCODE_TIMEOUT_MS=120000
# Optional für einen kontrollierten lokalen Test, nicht für produktionsnahe Isolation:
# PTSPACE_HARNESS=opencode-docker
# PTSPACE_REAL_HARNESS_ENABLED=true
# PTSPACE_OPENCODE_RUNNER=local
# PTSPACE_OPENCODE_MODEL=provider/model
BACKEND_PORT=5174
PUBLIC_BACKEND_URL=http://localhost:5174
